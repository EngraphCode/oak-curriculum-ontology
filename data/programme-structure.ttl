# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/oakcurriculum/programme-structure>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Programme Structure Instance Data"@en ;
  dc:title "Oak Curriculum Data - Programme Structure Instance Data"@en ;
  rdfs:comment """Instance data defining the exam boards and tiers used in Oak National Academy
  curriculum programmes."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/programme-structure/0.1.1> ;
  owl:priorVersion <https://w3id.org/uk/oak/curriculum/oakcurriculum/programme-structure/0.1.0> ;

  dcterms:description """Instance data defining the exam boards and tiers used in Oak National Academy
  curriculum programmes."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2026-06-07T15:30:51.696992Z"^^xsd:dateTime ;
  dcterms:modified "2026-06-07T15:30:51.696992Z"^^xsd:dateTime ;
  dcterms:issued "2026-06-07T15:30:51.696992Z"^^xsd:dateTime ;

  # OGL 3.0 License
