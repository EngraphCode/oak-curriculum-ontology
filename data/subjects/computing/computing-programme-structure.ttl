nat:scheme-computing-key-stage-4
  a natcurric:Scheme ;
  rdfs:label "Computing Key Stage 4"@en ;
  dcterms:description """All pupils must have the opportunity to study aspects of information
  technology and computer science at sufficient depth to allow them to progress to higher levels of
  study or to a professional career."""@en ;
