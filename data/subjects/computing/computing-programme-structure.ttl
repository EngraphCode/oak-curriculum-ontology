# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

nat:subjectgroup-computing
  a natcurric:SubjectGroup ;
  rdfs:label "Computing"@en ;
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime ;
  natcurric:coversDiscipline nat:discipline-computing .

# ----------------------------------------------------------------------
# Subjects
# ----------------------------------------------------------------------

nat:subject-computing
  a natcurric:Subject ;
  rdfs:label "Computing"@en ;
  natcurric:rationale """A high-quality computing education equips pupils to use computational 
  thinking and creativity to understand and change the world. Computing has deep links with 
  mathematics, science, and design and technology, and provides insights into both natural and 
  artificial systems. The core of computing is computer science, in which pupils are taught the 
  principles of information and computation, how digital systems work, and how to put this 
  knowledge to use through programming. Building on this knowledge and understanding, pupils are 
  equipped to use information technology to create programs, systems and a range of content. 
  Computing also ensures that pupils become digitally literate – able to use, and express 
  themselves and develop their ideas through, information and communication technology – at a level 
  suitable for the future workplace and as active participants in a digital world."""@en ;
  natcurric:hasAim
    nat:aim-computing-fundamental-principles-concepts-computer-science ,
    nat:aim-computing-analyse-problems-writing-computer-programs ,
    nat:aim-computing-evaluate-apply-information-technology-analytically ,
    nat:aim-computing-responsible-competent-users-information-technology ; 
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime ;
  natcurric:isSubjectOf nat:subjectgroup-computing ;
  natcurric:coversStrand nat:strand-computing .

# ----------------------------------------------------------------------
# Aims
# ----------------------------------------------------------------------

nat:aim-computing-fundamental-principles-concepts-computer-science
  a natcurric:Aim ;
  rdfs:label """Can understand and apply the fundamental principles and concepts of computer 
  science, including abstraction, logic, algorithms and data representation."""@en ;
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime .

nat:aim-computing-analyse-problems-writing-computer-programs
  a natcurric:Aim ;
  rdfs:label """Can analyse problems in computational terms, and have repeated practical experience 
  of writing computer programs in order to solve such problems."""@en ;
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime .

nat:aim-computing-evaluate-apply-information-technology-analytically
  a natcurric:Aim ;
  rdfs:label """Can evaluate and apply information technology, including new or unfamiliar 
  technologies, analytically to solve problems."""@en ;
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime .

nat:aim-computing-responsible-competent-users-information-technology
  a natcurric:Aim ;
  rdfs:label """Are responsible, competent, confident and creative users of information and 
  communication technology."""@en ;
  dcterms:modified "2026-05-04T14:53:53Z"^^xsd:dateTime .

