  skos:broader nat:contentdescriptor-identify-tenses-other-structures-convey ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-manipulate-variety-key-grammatical-structures
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Use and manipulate a variety of key grammatical structures and patterns,
  including voices and moods, as appropriate."""@en ;
  skos:broader nat:contentdescriptor-manipulate-variety-key-grammatical-structures ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-ranging-deepening-vocabulary-goes-immediate
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Develop and use a wide-ranging and deepening vocabulary that goes beyond their
  immediate needs and interests, allowing them to give and justify opinions and take part in
  discussion about wider issues."""@en ;
  skos:broader nat:contentdescriptor-ranging-deepening-vocabulary-goes-immediate ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-accurate-grammar-spelling-punctuation
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel "Use accurate grammar, spelling and punctuation."@en ;
  skos:broader nat:contentdescriptor-accurate-grammar-spelling-punctuation ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-listen-variety-forms-spoken-language
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Listen to a variety of forms of spoken language to obtain information and
  respond appropriately."""@en ;
  skos:broader nat:contentdescriptor-listen-variety-forms-spoken-language ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-transcribe-words-short-sentences-hear
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Transcribe words and short sentences that they hear with increasing
  accuracy."""@en ;
  skos:broader nat:contentdescriptor-transcribe-words-short-sentences-hear ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-initiate-conversations-coping-unfamiliar-language
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Initiate and develop conversations, coping with unfamiliar language and
  unexpected responses, making use of important social conventions such as formal modes of
  address."""@en ;
  skos:broader nat:contentdescriptor-initiate-conversations-coping-unfamiliar-language ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-express-ideas-increasing-accuracy-writing
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Express and develop ideas clearly and with increasing accuracy, both orally and
  in writing."""@en ;
  skos:broader nat:contentdescriptor-express-ideas-increasing-accuracy-writing ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-speak-accurate-pronunciation-intonation
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Speak coherently and confidently, with increasingly accurate pronunciation and
  intonation."""@en ;
  skos:broader nat:contentdescriptor-speak-accurate-pronunciation-intonation ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-read-comprehension-original-adapted-materials
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Read and show comprehension of original and adapted materials from a range of
  different sources, understanding the purpose, important ideas and details, and provide an
  accurate English translation of short, suitable material."""@en ;
  skos:broader nat:contentdescriptor-read-comprehension-original-adapted-materials ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-read-literary-texts-language-such
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Read literary texts in the language [such as stories, songs, poems and letters],
  to stimulate ideas, develop creative expression and expand understanding of the language
  and culture."""@en ;
  skos:broader nat:contentdescriptor-read-literary-texts-language-such ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .

nat:subcontentdescriptor-write-prose-wide-range-grammar
  a skos:Concept, natcurric:SubContentDescriptor ;
  skos:prefLabel """Write prose using an increasingly wide range of grammar and vocabulary, write
  creatively to express their own ideas and opinions, and translate short written text
  accurately into the foreign language."""@en ;
  skos:broader nat:contentdescriptor-write-prose-wide-range-grammar ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T11:12:00Z"^^xsd:dateTime .
