# ======================================================================
# National Curriculum for England - Mathematics Knowledge Taxonomy
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/curriculum/nat-data-2014/mathematics-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Mathematics Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Mathematics Knowledge Taxonomy"@en ;
  rdfs:comment """Mathematics knowledge taxonomy defining the hierarchical organisation of content
  from strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/curriculum/nat-data-2014/mathematics-knowledge-taxonomy/0.1.0> ;

  dcterms:description """This file defines the Mathematics knowledge taxonomy for the National
  Curriculum in England, organising content through strands, sub-strands, content
  descriptors, and sub-content descriptors."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-06T15:20:11Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-06T15:20:11Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  rdfs:seeAlso <https://w3id.org/uk/curriculum/nat-ontology> ;

  vann:preferredNamespacePrefix "nat" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/curriculum/nat-data-2014/" ;

  owl:imports <https://w3id.org/uk/curriculum/nat-ontology> ;
  owl:imports <https://w3id.org/uk/curriculum/nat-data-2014/mathematics-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

nat:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept nat:discipline-mathematics ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

nat:discipline-mathematics
  a skos:Concept, natcurric:Discipline ;
  skos:prefLabel "Mathematics"@en ;
  skos:topConceptOf nat:knowledge-taxonomy ;
  skos:narrower
    nat:strand-number ,
    nat:strand-measurement ,
    nat:strand-geometry ,
    nat:strand-statistics ,
    nat:strand-ratio-and-proportion ,
    nat:strand-algebra ,
    nat:strand-working-mathematically ,
    nat:strand-mathematics ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

