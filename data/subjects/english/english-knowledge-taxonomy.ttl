# Content Descriptors
# ----------------------------------------------------------------------

nat:contentdescriptor-apply-phonic-skills-route-decode
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel "Apply phonic knowledge and skills as the route to decode words."@en ;
  skos:broader nat:substrand-word-reading ;
  skos:narrower nat:subcontentdescriptor-apply-phonic-skills-route-decode ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-12T23:01:09Z"^^xsd:dateTime .

nat:contentdescriptor-respond-correct-sound-graphemes-letters
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Respond speedily with the correct sound to graphemes (letters or groups of
  letters) for all 40+ phonemes, including, where applicable, alternative sounds for
