@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ======================================================================
# National Curriculum for England - Physical education Knowledge Taxonomy
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/curriculum/nat-data-2014/physical-education-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Physical education Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Physical education Knowledge Taxonomy"@en ;
  rdfs:comment """Physical education knowledge taxonomy defining the hierarchical organisation of
  content from strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/curriculum/nat-data-2014/physical-education-knowledge-taxonomy/0.1.0> ;

  dcterms:description """This file defines the Physical education knowledge taxonomy for the
  National Curriculum in England, organising content through strands, sub-strands, content
  descriptors, and sub-content descriptors."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-04T18:01:20Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-04T18:01:20Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  rdfs:seeAlso <https://w3id.org/uk/curriculum/nat-ontology> ;

  vann:preferredNamespacePrefix "nat" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/curriculum/nat-data-2014/" ;

  owl:imports <https://w3id.org/uk/curriculum/nat-ontology> ;
  owl:imports <https://w3id.org/uk/curriculum/nat-data-2014/physical-education-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

nat:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept nat:discipline-physical-education ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

nat:discipline-physical-education
  a skos:Concept, natcurric:Discipline ;
  skos:prefLabel "Physical education"@en ;
  skos:topConceptOf nat:knowledge-taxonomy ;
  skos:narrower
    nat:strand-physical-education ,
    nat:strand-swimming-and-water-safety ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

nat:strand-physical-education
  a skos:Concept, natcurric:Strand ;
  skos:prefLabel "Physical education"@en ;
  skos:definition "Description of strand..."@en ;
  skos:broader nat:discipline-physical-education ;
  skos:narrower nat:substrand-physical-education ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:strand-swimming-and-water-safety
  a skos:Concept, natcurric:Strand ;
  skos:prefLabel "Swimming and water safety"@en ;
  skos:definition "Description of strand..."@en ;
  skos:broader nat:discipline-physical-education ;
  skos:narrower nat:substrand-swimming-and-water-safety ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Sub-Strands
# ----------------------------------------------------------------------

nat:substrand-physical-education
  a skos:Concept, natcurric:SubStrand ;
  skos:prefLabel "Physical education"@en ;
  skos:broader nat:strand-physical-education ;
  skos:narrower
    nat:contentdescriptor-master-basic-movements-running-jumping ,
    nat:contentdescriptor-participate-team-games-simple-tactics ,
    nat:contentdescriptor-perform-dances-simple-movement-patterns ,
    nat:contentdescriptor-running-jumping-throwing-catching-isolation ,
    nat:contentdescriptor-play-competitive-games-modified-appropriate ,
    nat:contentdescriptor-flexibility-strength-technique-control-balance ,
    nat:contentdescriptor-perform-dances-range-movement-patterns ,
    nat:contentdescriptor-take-part-outdoor-adventurous-activity ,
    nat:contentdescriptor-compare-performances-previous-ones-improvement ,
    nat:contentdescriptor-range-tactics-strategies-overcome-opponents ,
    nat:contentdescriptor-develop-technique-in-competitive-sports ,
    nat:contentdescriptor-perform-dances-advanced-dance-techniques ,
    nat:contentdescriptor-take-part-outdoor-adventurous-activities ,
    nat:contentdescriptor-analyse-performances-compared-previous-ones ,
    nat:contentdescriptor-take-part-competitive-sports-activities ,
    nat:contentdescriptor-variety-tactics-strategies-overcome-opponents ,
    nat:contentdescriptor-improve-performance-in-competitive-sports ,
    nat:contentdescriptor-take-part-further-outdoor-adventurous ,
    nat:contentdescriptor-evaluate-performances-compared-previous-ones ,
    nat:contentdescriptor-continue-take-part-competitive-sports ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:substrand-swimming-and-water-safety
  a skos:Concept, natcurric:SubStrand ;
  skos:prefLabel "Swimming and water safety"@en ;
  skos:broader nat:strand-swimming-and-water-safety ;
  skos:narrower
    nat:contentdescriptor-swim-distance-25-metres ,
    nat:contentdescriptor-range-strokes-example-front-crawl ,
    nat:contentdescriptor-perform-safe-self-rescue-different ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Content Descriptors
# ----------------------------------------------------------------------

nat:contentdescriptor-master-basic-movements-running-jumping
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Master basic movements including running, jumping, throwing and catching, as
  well as developing balance, agility and co-ordination, and begin to apply these in a range of 
  activities."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-master-basic-movements-running-jumping ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-participate-team-games-simple-tactics
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Participate in team games, developing simple tactics for attacking and
  defending."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-participate-team-games-simple-tactics ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-perform-dances-simple-movement-patterns
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel "Perform dances using simple movement patterns."@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-perform-dances-simple-movement-patterns ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-running-jumping-throwing-catching-isolation
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel "Use running, jumping, throwing and catching in isolation and in combination."@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-running-jumping-throwing-catching-isolation ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-play-competitive-games-modified-appropriate
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Play competitive games, modified where appropriate [for example, badminton,
  basketball, cricket, football, hockey, netball, rounders and tennis], and apply basic principles 
  suitable for attacking and defending."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-play-competitive-games-modified-appropriate ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-flexibility-strength-technique-control-balance
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Develop flexibility, strength, technique, control and balance [for example,
  through athletics and gymnastics]."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-flexibility-strength-technique-control-balance ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-perform-dances-range-movement-patterns
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel "Perform dances using a range of movement patterns."@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-perform-dances-range-movement-patterns ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-take-part-outdoor-adventurous-activity
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Take part in outdoor and adventurous activity challenges both individually and
  within a team."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-take-part-outdoor-adventurous-activity ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-compare-performances-previous-ones-improvement
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Compare their performances with previous ones and demonstrate improvement to
  achieve their personal best."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-compare-performances-previous-ones-improvement ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-swim-distance-25-metres
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Swim competently, confidently and proficiently over a distance of at least 25
  metres."""@en ;
  skos:broader nat:substrand-swimming-and-water-safety ;
  skos:narrower nat:subcontentdescriptor-swim-distance-25-metres ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-range-strokes-example-front-crawl
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Use a range of strokes effectively [for example, front crawl, backstroke and
  breaststroke]."""@en ;
  skos:broader nat:substrand-swimming-and-water-safety ;
  skos:narrower nat:subcontentdescriptor-range-strokes-example-front-crawl ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-perform-safe-self-rescue-different
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel "Perform safe self-rescue in different water-based situations."@en ;
  skos:broader nat:substrand-swimming-and-water-safety ;
  skos:narrower nat:subcontentdescriptor-perform-safe-self-rescue-different ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-range-tactics-strategies-overcome-opponents
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Use a range of tactics and strategies to overcome opponents in direct
  competition through team and individual games [for example, badminton, basketball, cricket, 
  football, hockey, netball, rounders, rugby and tennis]."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-range-tactics-strategies-overcome-opponents ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-develop-technique-in-competitive-sports
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Develop their technique and improve their performance in other competitive
  sports [for example, athletics and gymnastics]."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-develop-technique-in-competitive-sports ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-perform-dances-advanced-dance-techniques
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Perform dances using advanced dance techniques within a range of dance styles
  and forms."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-perform-dances-advanced-dance-techniques ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-take-part-outdoor-adventurous-activities
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Take part in outdoor and adventurous activities which present intellectual and
  physical challenges and be encouraged to work in a team, building on trust and developing skills 
  to solve problems, either individually or as a group."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-take-part-outdoor-adventurous-activities ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-analyse-performances-compared-previous-ones
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Analyse their performances compared to previous ones and demonstrate 
  improvement to achieve their personal best."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-analyse-performances-compared-previous-ones ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-take-part-competitive-sports-activities
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Take part in competitive sports and activities outside school through community
  links or sports clubs."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-take-part-competitive-sports-activities ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-variety-tactics-strategies-overcome-opponents
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Use and develop a variety of tactics and strategies to overcome opponents in
  team and individual games [for example, badminton, basketball, cricket, football, hockey, 
  netball, rounders, rugby and tennis]."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-variety-tactics-strategies-overcome-opponents ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-improve-performance-in-competitive-sports
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Develop their technique and improve their performance in other competitive
  sports,[for example, athletics and gymnastics], or other physical activities [for example,
  dance]."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-improve-performance-in-competitive-sports ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-take-part-further-outdoor-adventurous
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Take part in further outdoor and adventurous activities in a range of
  environments which present intellectual and physical challenges and which encourage pupils to 
  work in a team, building on trust and developing skills to solve problems, either individually or 
  as a group."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-take-part-further-outdoor-adventurous ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-evaluate-performances-compared-previous-ones
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Evaluate their performances compared to previous ones and demonstrate
  improvement across a range of physical activities to achieve their personal best."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-evaluate-performances-compared-previous-ones ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

nat:contentdescriptor-continue-take-part-competitive-sports
  a skos:Concept, natcurric:ContentDescriptor ;
  skos:prefLabel """Continue to take part regularly in competitive sports and activities outside
  school through community links or sports clubs."""@en ;
  skos:broader nat:substrand-physical-education ;
  skos:narrower nat:subcontentdescriptor-continue-take-part-competitive-sports ;
  skos:inScheme nat:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime .

