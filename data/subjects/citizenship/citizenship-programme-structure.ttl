# Progressions
# ----------------------------------------------------------------------

nat:progression-citizenship-key-stage-3-citizenship
  a natcurric:Progression ;
  rdfs:label "Citizenship Key Stage 3 Citizenship"@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-citizenship-key-stage-3 ;
  natcurric:coversSubStrand nat:substrand-citizenship ;
  natcurric:includesContentDescriptor
