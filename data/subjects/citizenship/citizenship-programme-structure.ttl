    nat:contentdescriptor-roles-played-public-institutions-voluntary ,
    nat:contentdescriptor-functions-money-importance-practice-budgeting .

nat:progression-citizenship-key-stage-4-citizenship
  a natcurric:Progression ;
  rdfs:label "Citizenship Key Stage 4 Citizenship"@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-citizenship-key-stage-4 ;
  natcurric:coversSubStrand nat:substrand-citizenship ;
  natcurric:includesContentDescriptor
    nat:contentdescriptor-parliamentary-democracy-key-elements-constitution ,
    nat:contentdescriptor-different-electoral-systems-used-united ,
