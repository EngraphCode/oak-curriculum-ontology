# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

nat:subjectgroup-citizenship
  a natcurric:SubjectGroup ;
  rdfs:label "Citizenship"@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:coversDiscipline nat:discipline-citizenship .

# ----------------------------------------------------------------------
# Subjects
# ----------------------------------------------------------------------

nat:subject-citizenship
  a natcurric:Subject ;
  rdfs:label "Citizenship"@en ;
  natcurric:rationale """A high-quality citizenship education helps to provide pupils with 
  knowledge, skills and understanding to prepare them to play a full and active part in society. In 
  particular, citizenship education should foster pupils’ keen awareness and understanding of 
  democracy, government and how laws are made and upheld. Teaching should equip pupils with the 
  skills and knowledge to explore political and social issues critically, to weigh evidence, debate 
  and make reasoned arguments. It should also prepare pupils to take their place in society as 
  responsible citizens, manage their money well and make sound financial decisions."""@en ;
  natcurric:hasAim
    nat:aim-citizenship-uk-governed-political-democratic-systems ,
    nat:aim-citizenship-law-and-justice-system ,
    nat:aim-citizenship-participation-volunteering-responsible-activity ,
    nat:aim-citizenship-political-questions-money-financial-needs ; 
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:isSubjectOf nat:subjectgroup-citizenship ;
  natcurric:coversStrand nat:strand-citizenship .

# ----------------------------------------------------------------------
# Aims
# ----------------------------------------------------------------------

nat:aim-citizenship-uk-governed-political-democratic-systems
  a natcurric:Aim ;
  rdfs:label """Acquire a sound knowledge and understanding of how the United Kingdom is governed, 
  its political system and how citizens participate actively in its democratic systems of 
  government."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

nat:aim-citizenship-law-and-justice-system
  a natcurric:Aim ;
  rdfs:label """Develop a sound knowledge and understanding of the role of law and the justice 
  system in our society and how laws are shaped and enforced."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

nat:aim-citizenship-participation-volunteering-responsible-activity
  a natcurric:Aim ;
  rdfs:label """Develop an interest in, and commitment to, participation in volunteering as well as 
  other forms of responsible activity, that they will take with them into adulthood."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

nat:aim-citizenship-political-questions-money-financial-needs
  a natcurric:Aim ;
  rdfs:label """Are equipped with the skills to think critically and debate political questions, to 
  enable them to manage their money on a day-to-day basis, and plan for future financial 
  needs."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Schemes
# ----------------------------------------------------------------------

nat:scheme-citizenship-key-stage-3
  a natcurric:Scheme ;
  rdfs:label "Citizenship Key Stage 3"@en ;
  dcterms:description """Teaching should develop pupils’ understanding of democracy, government and 
  the rights and responsibilities of citizens. Pupils should use and apply their knowledge and 
  understanding whilst developing skills to research and interrogate evidence, debate and evaluate 
  viewpoints, present reasoned arguments and take informed action."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-citizenship ;
  natcurric:coversKeyStage nat:key-stage-3 .

nat:scheme-citizenship-key-stage-4
  a natcurric:Scheme ;
  rdfs:label "Citizenship Key Stage 4"@en ;
  dcterms:description """Teaching should build on the key stage 3 programme of study to deepen 
  pupils’ understanding of democracy, government and the rights and responsibilities of citizens. 
  Pupils should develop their skills to be able to use a range of research strategies, weigh up 
  evidence, make persuasive arguments and substantiate their conclusions. They should experience 
  and evaluate different ways that citizens can act together to solve problems and contribute to 
  society."""@en ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-citizenship ;
  natcurric:coversKeyStage nat:key-stage-4 .

