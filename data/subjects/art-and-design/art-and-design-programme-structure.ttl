# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

nat:subjectgroup-art-and-design
  a natcurric:SubjectGroup ;
  rdfs:label "Art and design"@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:coversDiscipline nat:discipline-art-and-design .

# ----------------------------------------------------------------------
# Subjects 
# ----------------------------------------------------------------------

nat:subject-art-and-design
  a natcurric:Subject ;
  rdfs:label "Art and design"@en ;
  natcurric:rationale """Art, craft and design embody some of the highest forms of human 
  creativity. A high-quality art and design education should engage, inspire and challenge pupils, 
  equipping them with the knowledge and skills to experiment, invent and create their own works of 
  art, craft and design. As pupils progress, they should be able to think critically and develop a 
  more rigorous understanding of art and design. They should also know how art and design both 
  reflect and shape our history, and contribute to the culture, creativity and wealth of our 
  nation."""@en ;
  natcurric:hasAim
    nat:aim-art-and-design-produce-creative-work-exploring-ideas ,
    nat:aim-art-and-design-proficient-art-craft-design-techniques ,
    nat:aim-art-and-design-evaluate-and-analyse-creative-works ,
    nat:aim-art-and-design-great-artists-craft-makers-designers ; 
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isSubjectOf nat:subjectgroup-art-and-design ;
  natcurric:coversStrand nat:strand-art-and-design .

# ----------------------------------------------------------------------
# Aims
# ----------------------------------------------------------------------

nat:aim-art-and-design-produce-creative-work-exploring-ideas
  a natcurric:Aim ;
  rdfs:label "Produce creative work, exploring their ideas and recording their experiences."@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime .

nat:aim-art-and-design-proficient-art-craft-design-techniques
  a natcurric:Aim ;
  rdfs:label """Become proficient in drawing, painting, sculpture and other art, craft and design 
  techniques."""@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime .

nat:aim-art-and-design-evaluate-and-analyse-creative-works
  a natcurric:Aim ;
  rdfs:label "Evaluate and analyse creative works using the language of art, craft and design."@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime .

nat:aim-art-and-design-great-artists-craft-makers-designers
  a natcurric:Aim ;
  rdfs:label """Know about great artists, craft makers and designers, and understand the historical 
  and cultural development of their art forms."""@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Schemes
# ----------------------------------------------------------------------

nat:scheme-art-and-design-key-stage-1
  a natcurric:Scheme ;
  rdfs:label "Art and design Key Stage 1"@en ;
  dcterms:description "No key stage description."@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-art-and-design ;
  natcurric:coversKeyStage nat:key-stage-1 .

nat:scheme-art-and-design-key-stage-2
  a natcurric:Scheme ;
  rdfs:label "Art and design Key Stage 2"@en ;
  dcterms:description """Pupils should be taught to develop their techniques, including their 
  control and their use of materials, with creativity, experimentation and an increasing awareness 
  of different kinds of art, craft and design."""@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-art-and-design ;
  natcurric:coversKeyStage nat:key-stage-2 .

nat:scheme-art-and-design-key-stage-3
  a natcurric:Scheme ;
  rdfs:label "Art and design Key Stage 3"@en ;
  dcterms:description """Pupils should be taught to develop their creativity and ideas, and 
  increase proficiency in their execution. They should develop a critical understanding of artists, 
  architects and designers, expressing reasoned judgements that can inform their own work."""@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-art-and-design ;
  natcurric:coversKeyStage nat:key-stage-3 .

# ----------------------------------------------------------------------
# Progressions
# ----------------------------------------------------------------------

nat:progression-art-and-design-key-stage-1-art-and-design
  a natcurric:Progression ;
  rdfs:label "Art and design Key Stage 1 Art and design"@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-art-and-design-key-stage-1 ;
  natcurric:coversSubStrand nat:substrand-art-and-design ;
  natcurric:includesContentDescriptor
    nat:contentdescriptor-range-materials-design-products ,
    nat:contentdescriptor-drawing-painting-sculpture-share-ideas ,
    nat:contentdescriptor-wide-range-art-design-techniques ,
    nat:contentdescriptor-range-artists-craft-makers-designers .

nat:progression-art-and-design-key-stage-2-art-and-design
  a natcurric:Progression ;
  rdfs:label "Art and design Key Stage 2 Art and design"@en ;
  dcterms:modified "2026-05-04T13:57:52Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-art-and-design-key-stage-2 ;
  natcurric:coversSubStrand nat:substrand-art-and-design ;
  natcurric:includesContentDescriptor
    nat:contentdescriptor-create-sketch-books-record-observations ,
