  vann:preferredNamespacePrefix "nat" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/curriculum/nat-data-2014/" ;

  owl:imports <https://w3id.org/uk/curriculum/nat-ontology> ;
  owl:imports <https://w3id.org/uk/curriculum/nat-data-2014/temporal-structure> ;
  owl:imports <https://w3id.org/uk/curriculum/nat-data-2014/music-knowledge-taxonomy> .

# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

nat:subjectgroup-music
  a natcurric:SubjectGroup ;
  rdfs:label "Music"@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:coversDiscipline nat:discipline-music .

# ----------------------------------------------------------------------
# Subjects
# ----------------------------------------------------------------------

nat:subject-music
  a natcurric:Subject ;
  rdfs:label "Music"@en ;
  natcurric:rationale """Music is a universal language that embodies one of the highest forms of 
  creativity. A high quality music education should engage and inspire pupils to develop a love of 
  music and their talent as musicians, and so increase their self-confidence, creativity and sense 
  of achievement. As pupils progress, they should develop a critical engagement with music, 
  allowing them to compose, and to listen with discrimination to the best in the musical 
  canon."""@en ;
  natcurric:hasAim
    nat:aim-music-perform-listen-evaluate-music ,
    nat:aim-music-sing-compose-musical-instrument-technology ,
    nat:aim-music-how-music-created-produced-communicated ; 
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isSubjectOf nat:subjectgroup-music ;
  natcurric:coversStrand nat:strand-music .

# ----------------------------------------------------------------------
# Aims
# ----------------------------------------------------------------------

nat:aim-music-perform-listen-evaluate-music
  a natcurric:Aim ;
  rdfs:label """Perform, listen to, review and evaluate music across a range of historical periods, 
  genres, styles and traditions, including the works of the great composers and musicians."""@en ;
  dcterms:modified "2026-05-04T15:18:34Z"^^xsd:dateTime .

nat:aim-music-sing-compose-musical-instrument-technology
  a natcurric:Aim ;
  rdfs:label """Learn to sing and to use their voices, to create and compose music on their own and 
  with others, have the opportunity to learn a musical instrument, use technology appropriately and 
  have the opportunity to progress to the next level of musical excellence."""@en ;
  dcterms:modified "2026-05-04T15:18:34Z"^^xsd:dateTime .

nat:aim-music-how-music-created-produced-communicated
  a natcurric:Aim ;
  rdfs:label """Understand and explore how music is created, produced and communicated, including 
  through the inter-related dimensions: pitch, duration, dynamics, tempo, timbre, texture, 
  structure and appropriate musical notations."""@en ;
  dcterms:modified "2026-05-04T15:18:34Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Schemes
# ----------------------------------------------------------------------

nat:scheme-music-key-stage-1
  a natcurric:Scheme ;
  rdfs:label "Music Key Stage 1"@en ;
  dcterms:description "No key stage description."@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-music ;
  natcurric:coversKeyStage nat:key-stage-1 .

nat:scheme-music-key-stage-2
  a natcurric:Scheme ;
  rdfs:label "Music Key Stage 2"@en ;
  dcterms:description """Pupils should be taught to sing and play musically with increasing 
  confidence and control. They should develop an understanding of musical composition, organising 
  and manipulating ideas within musical structures and reproducing sounds from aural memory."""@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-music ;
  natcurric:coversKeyStage nat:key-stage-2 .

nat:scheme-music-key-stage-3
  a natcurric:Scheme ;
  rdfs:label "Music Key Stage 3"@en ;
  dcterms:description """Pupils should build on their previous knowledge and skills through 
  performing, composing and listening. They should develop their vocal and/or instrumental fluency, 
  accuracy and expressiveness; and understand musical structures, styles, genres and traditions, 
  identifying the expressive use of musical dimensions. They should listen with increasing 
  discrimination and awareness to inform their practice as musicians. They should use technologies 
  appropriately and appreciate and understand a wide range of musical contexts and styles."""@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isSchemeOf nat:subject-music ;
  natcurric:coversKeyStage nat:key-stage-3 .

# ----------------------------------------------------------------------
# Progressions
# ----------------------------------------------------------------------

nat:progression-music-key-stage-1-music
  a natcurric:Progression ;
  rdfs:label "Music Key Stage 1 Music"@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-music-key-stage-1 ;
  natcurric:coversSubStrand nat:substrand-music ;
  natcurric:includesContentDescriptor
    nat:contentdescriptor-voices-singing-songs-speaking-chants ,
    nat:contentdescriptor-play-tuned-untuned-instruments ,
    nat:contentdescriptor-listen-concentration-range-high-quality ,
    nat:contentdescriptor-experiment-create-select-combine-sounds .

nat:progression-music-key-stage-2-music
  a natcurric:Progression ;
  rdfs:label "Music Key Stage 2 Music"@en ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  natcurric:isProgressionOf nat:scheme-music-key-stage-2 ;
  natcurric:coversSubStrand nat:substrand-music ;
  natcurric:includesContentDescriptor
    nat:contentdescriptor-play-perform-solo-ensemble-contexts ,
    nat:contentdescriptor-improvise-compose-music-range-purposes ,
    nat:contentdescriptor-listen-attention-detail-recall-sounds ,
    nat:contentdescriptor-staff-other-musical-notations ,
    nat:contentdescriptor-appreciate-wide-range-high-quality ,
