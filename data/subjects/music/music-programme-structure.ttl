# ======================================================================
# National Curriculum for England - Music Programme Structure
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/curriculum/nat-data-2014/music-programme-structure>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Music Programme Structure"@en ;
  dc:title "National Curriculum for England - Music Programme Structure"@en ;
  rdfs:comment """Music programme structure that specifies schemes and progressions, and a mapping
  to strands, sub-strands and content descriptors within the knowledge taxonomy."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/curriculum/nat-data-2014/music-programme-structure/0.1.0> ;

  dcterms:description """Music programme structure that specifies schemes and progressions, and a
  mapping to strands, sub-strands and content descriptors within the knowledge taxonomy."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-05T15:05:11Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-05T15:05:11Z"^^xsd:dateTime ;

